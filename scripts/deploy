#!/bin/zsh

set -e

echo "Deploying changes from 'develop' to 'main' branch..."
git checkout main $2> /dev/null || {
  echo "Error: Could not switch to 'main' branch. Please ensure it exists."
  exit 1
}
git pull origin main $2> /dev/null || {
  echo "Error: Could not pull latest changes from 'main' branch."
  exit 1
}

echo "Merging 'develop' into 'main' branch..."
git merge develop --strategy-option theirs --no-ff --message "Merge branch 'develop' into main" $2> /dev/null || {
  echo "Error: Merge conflict occurred. Please resolve conflicts manually."
  exit 1
}

echo "Pushing changes to 'main' branch..."
git push origin main $2> /dev/null || {
  echo "Error: Could not push changes to 'main' branch."
  exit 1
}
git checkout develop $2> /dev/null || {
  echo "Error: Could not switch back to 'develop' branch."
  exit 1
}