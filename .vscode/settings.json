{
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "vknabel.vscode-apple-swift-format",
  "swift.workspaceSymbol.ignorePaths": [".build", "assets"],
  "files.exclude": {
    "**/.build": true,
    "**/.DS_Store": true
  },
  "files.associations": {
    "Makefile": "makefile",
    "*.md": "markdown"
  },
  "search.exclude": {
    "**/.build": true,
    "**/dist": true
  },
  "terminal.integrated.defaultProfile.osx": "zsh"
}
