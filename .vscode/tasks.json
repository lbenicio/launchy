{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "swift: Build Debug Launchy",
      "type": "shell",
      "command": "swift",
      "args": ["build"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "swift: Build Release Launchy",
      "type": "shell",
      "command": "swift",
      "args": ["build", "-c", "release"],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "swift: Run Tests",
      "type": "shell",
      "command": "swift",
      "args": ["test"],
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "make run",
      "type": "shell",
      "command": "make",
      "args": ["run"],
      "group": "none",
      "problemMatcher": []
    },
    {
      "label": "make deploy --dry-run",
      "type": "shell",
      "command": "make",
      "args": ["deploy", "DEPLOY_ARGS=--dry-run"],
      "problemMatcher": []
    }
  ]
}
